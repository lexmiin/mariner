---
import PageChrome from '@/layouts/PageChrome.astro'
import { getStoryCatalog } from '@/lib/story-content'

const catalog = getStoryCatalog()
const story = await catalog.findStory('page', 'landing')
if (!story) throw new Error('Landing Story not found')
---

<PageChrome {story}>
  <link
    slot="head"
    rel="preload"
    as="image"
    href="/images/home-poster.webp"
    fetchpriority="high"
  />
  <link
    slot="head"
    rel="preconnect"
    href="https://media.marinerworldwide.com"
  />
</PageChrome>
