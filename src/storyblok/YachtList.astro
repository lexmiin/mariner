---
import YachtCard from '@/components/YachtCard.astro'
import { getStoryCatalog } from '@/lib/story-content'
import { projectYachtSummary } from '@/lib/yacht-summary'
import { storyblokEditable } from '@storyblok/astro'

const { blok } = Astro.props
const catalog = getStoryCatalog()
const stories = await catalog.listStories('yacht')
const yachts = stories.map(projectYachtSummary)
---

<section
  class="content-block bg-background"
  data-block="yacht-list"
  {...storyblokEditable(blok)}
>
  <div class="content-container max-w-6xl">
    {
      yachts.length > 0 ? (
        <ol class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {yachts.map((yacht, index) => (
            <li>
              <YachtCard summary={yacht} index={index + 1} />
            </li>
          ))}
        </ol>
      ) : (
        <p class="text-muted-foreground border-border border-y py-10">
          Yacht stories will appear here once they are published.
        </p>
      )
    }
  </div>
</section>
