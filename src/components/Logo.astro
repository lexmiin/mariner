---
interface Props {
  appearance?: 'default' | 'inverse'
}

const { appearance = 'default' } = Astro.props
---

<a href="/">
  <div class="group inline-flex items-center gap-2 py-2.5">
    {
      appearance === 'inverse' ? (
        <img
          alt="Mariner Worldwide logo"
          src="/images/logo-dark.png"
          class="h-7 w-7 transform transition-transform duration-700 ease-in-out group-hover:rotate-180"
        />
      ) : (
        <>
          <img
            alt="Mariner Worldwide logo"
            src="/images/logo.png"
            class="h-7 w-7 transform transition-transform duration-700 ease-in-out group-hover:rotate-180 group-data-[tone=inverse]/navbar:hidden"
          />
          <img
            alt=""
            aria-hidden="true"
            src="/images/logo-dark.png"
            class="hidden h-7 w-7 transform transition-transform duration-700 ease-in-out group-hover:rotate-180 group-data-[tone=inverse]/navbar:block"
          />
        </>
      )
    }
    <span class="font-cinzel text-sm font-semibold tracking-[0.12em]"
      >MARINERWORLDWIDE</span
    >
  </div>
</a>
