---
interface Props {
  label: string
  name?: string
  open?: boolean
  'data-blok-c'?: string
  'data-blok-uid'?: string
}

const { label, name, open = false, ...attributes } = Astro.props
---

<details class="group border-primary/70 border-b" {name} {open} {...attributes}>
  <summary
    class="font-cinzel text-foreground hover:text-accent focus-visible:outline-ring flex cursor-pointer list-none items-center justify-between gap-6 py-5 text-left text-sm tracking-[0.06em] uppercase transition-colors select-none focus-visible:relative focus-visible:z-10 focus-visible:outline-2 focus-visible:outline-offset-4 sm:text-base [&::-webkit-details-marker]:hidden"
  >
    {label}
    <svg
      aria-hidden="true"
      class="text-primary size-6 shrink-0 transition-transform duration-200 ease-out group-open:rotate-45 motion-reduce:transition-none"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="1.5"
    >
      <circle cx="12" cy="12" r="10.5"></circle>
      <path d="M7.5 12h9M12 7.5v9"></path>
    </svg>
  </summary>
  <slot />
</details>
